@model PostMatchSummary.Models.Player

@{
    ViewData["Title"] = "Uredi Igrača";
    var roles = (List<PostMatchSummary.Models.ChampionRole>?)ViewBag.Roles ?? new List<PostMatchSummary.Models.ChampionRole>();
    var champions = (List<PostMatchSummary.Models.Champion>?)ViewBag.Champions ?? new List<PostMatchSummary.Models.Champion>();
}

<style>
    .form-container {
        max-width: 700px;
        margin: 0 auto;
        padding: 24px;
        background: var(--bg-surface);
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    .form-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 24px;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .form-row.full {
        grid-template-columns: 1fr;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 6px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control, select {
        width: 100%;
        padding: 10px 12px;
        background: var(--bg-elevated);
        border: 2px solid var(--bg-surface);
        color: var(--text-primary);
        border-radius: 4px;
        font-size: 14px;
        transition: all 0.2s ease;
        box-sizing: border-box;
    }

    .form-control:focus, select:focus {
        outline: none;
        border-color: var(--accent-red);
        box-shadow: 0 0 0 3px rgba(233, 69, 96, 0.1);
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 8px;
    }

    .checkbox-group input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .form-buttons {
        display: flex;
        gap: 12px;
        margin-top: 32px;
    }

    .btn-submit, .btn-cancel, .btn-danger {
        flex: 1;
        padding: 12px 16px;
        border: none;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-submit {
        background: var(--accent-red);
        color: var(--text-primary);
    }

    .btn-submit:hover {
        background: #d43050;
        transform: translateY(-2px);
    }

    .btn-cancel {
        background: var(--bg-elevated);
        color: var(--text-primary);
        border: 1px solid var(--accent-red);
        text-decoration: none;
        text-align: center;
    }

    .btn-cancel:hover {
        background: var(--accent-red);
    }

    .btn-danger {
        background: var(--loss);
        color: var(--text-primary);
    }

    .btn-danger:hover {
        background: #d63650;
    }
</style>

<div class="form-container">
    <h1 class="form-title">Uredi Igrača</h1>

    <form method="post" action="/api/players/@Model.Id/edit">
        <div class="form-row full">
            <div class="form-group">
                <label for="SummonerName" class="form-label">Summoner Ime *</label>
                <input type="text" id="SummonerName" name="SummonerName" class="form-control" value="@Model.SummonerName" required />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="ChampionId_display" class="form-label">Champion</label>
                @{
                    var acChampion = new ViewDataDictionary(ViewData)
                    {
                        ["fieldName"] = "ChampionId",
                        ["endpoint"] = "/api/champions/search",
                        ["displayField"] = "name",
                        ["selectedId"] = Model?.ChampionId ?? 0,
                        ["selectedLabel"] = champions.FirstOrDefault(c => c.Id == Model?.ChampionId)?.Name ?? string.Empty
                    };
                }
                @await Html.PartialAsync("_AutocompleteDropdown", new object(), acChampion)
                <span class="field-error">@Html.ValidationMessage("ChampionId")</span>
            </div>

            <div class="form-group">
                <label for="Role" class="form-label">Role</label>
                <select id="Role" name="Role" class="form-select" required>
                    <option value="">— Select Role —</option>
                    @foreach (var role in roles)
                    {
                        if (Model?.Role == role)
                        {
                            <option value="@((int)role)" selected>@role</option>
                        }
                        else
                        {
                            <option value="@((int)role)">@role</option>
                        }
                    }
                </select>
                <span class="field-error">@Html.ValidationMessage("Role")</span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="Kills" class="form-label">Killsi</label>
                <input type="number" id="Kills" name="Kills" class="form-control" value="@Model.Kills" min="0" max="50" />
            </div>

            <div class="form-group">
                <label for="Deaths" class="form-label">Smrti</label>
                <input type="number" id="Deaths" name="Deaths" class="form-control" value="@Model.Deaths" min="0" max="50" />
            </div>

            <div class="form-group">
                <label for="Assists" class="form-label">Assistsi</label>
                <input type="number" id="Assists" name="Assists" class="form-control" value="@Model.Assists" min="0" max="50" />
            </div>

            <div class="form-group">
                <label for="CS" class="form-label">CS</label>
                <input type="number" id="CS" name="CS" class="form-control" value="@Model.CS" min="0" max="500" />
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="GoldEarned" class="form-label">Zlato Zaradljeno</label>
                <input type="number" id="GoldEarned" name="GoldEarned" class="form-control" value="@Model.GoldEarned" min="0" max="50000" />
            </div>

            <div class="form-group">
                <label class="form-label">Status</label>
                <div class="checkbox-group">
                    <input type="checkbox" id="Win" name="Win" value="true" @(Model.Win ? "checked" : "") />
                    <label for="Win">Pobio/la sam</label>
                </div>
            </div>
        </div>

        <div class="form-buttons">
            <button type="submit" class="btn-submit">✅ Spremi</button>
            <a href="/api/players/" class="btn-cancel">❌ Otkaži</a>
            <a href="/api/players/@Model.Id/delete" class="btn-danger">🗑️ Obriši</a>
        </div>
    </form>
</div>
