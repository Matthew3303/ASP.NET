@model PostMatchSummary.Models.Player

@{
    ViewData["Title"] = "Obriši Igrača";
}

<style>
    .delete-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 24px;
        background: rgba(233, 69, 96, 0.1);
        border: 2px solid var(--loss);
        border-radius: 8px;
    }

    .delete-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--loss);
        margin-bottom: 16px;
    }

    .delete-info {
        background: var(--bg-surface);
        padding: 16px;
        border-radius: 4px;
        margin: 16px 0;
        color: var(--text-primary);
    }

    .warning-box {
        background: rgba(233, 69, 96, 0.1);
        border-left: 4px solid var(--loss);
        padding: 12px;
        margin: 16px 0;
        color: var(--loss);
        font-size: 14px;
    }

    .form-buttons {
        display: flex;
        gap: 12px;
        margin-top: 24px;
    }

    .btn-danger, .btn-cancel {
        flex: 1;
        padding: 12px 16px;
        border: none;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
    }

    .btn-danger {
        background: var(--loss);
        color: var(--text-primary);
    }

    .btn-danger:hover {
        background: #d63650;
        transform: translateY(-2px);
    }

    .btn-cancel {
        background: var(--bg-elevated);
        color: var(--text-primary);
        border: 1px solid var(--text-muted);
    }

    .btn-cancel:hover {
        background: var(--bg-surface);
    }
</style>

<div class="delete-container">
    <h1 class="delete-title">⚠️ Obriši Igrača</h1>

    <div class="delete-info">
        <strong>@Model.SummonerName</strong>  
        @if (Model.Champion != null)
        {
            <span> - @await Html.PartialAsync("_ChampionBadge", Model.Champion) (@Model.Role)</span>
        }
    </div>

    <div class="warning-box">
        Brisanje je trajno i ne može se poništiti.
    </div>

    <form method="post" action="/api/players/@Model.Id/delete" style="display: flex; gap: 12px;">
        <button type="submit" class="btn-danger" style="flex: 1;">🗑️ Potvrdi Brisanje</button>
        <a href="/api/players/" class="btn-cancel" style="flex: 1;">❌ Otkaži</a>
    </form>
</div>
