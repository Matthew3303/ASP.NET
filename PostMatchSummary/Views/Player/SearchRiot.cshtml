@{
    ViewData["Title"] = "Search Player";
}

<style>
    .search-page {
        max-width: 600px;
        margin: 60px auto;
        text-align: center;
    }

    .search-logo { font-size: 48px; margin-bottom: 16px; }

    .search-title {
        font-size: 28px;
        font-weight: 700;
        color: #e0e0e0;
        margin-bottom: 8px;
    }

    .search-subtitle {
        font-size: 14px;
        color: #8892a4;
        margin-bottom: 40px;
    }

    .search-box {
        display: flex;
        background: #1a1a2e;
        border: 2px solid rgba(255,255,255,0.08);
        border-radius: 8px;
        overflow: hidden;
        transition: border-color 0.2s;
    }

    .search-box:focus-within { border-color: #e94560; }

    .search-input {
        flex: 1;
        padding: 16px 20px;
        background: transparent;
        border: none;
        color: #e0e0e0;
        font-size: 16px;
        outline: none;
    }

    .search-input::placeholder { color: #4a5568; }

    .search-btn {
        padding: 16px 28px;
        background: #e94560;
        border: none;
        color: white;
        font-size: 15px;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
    }

    .search-btn:hover { background: #ff6b7a; }

    .search-hint {
        margin-top: 12px;
        font-size: 12px;
        color: #4a5568;
    }

    .search-error {
        margin-top: 16px;
        padding: 12px 16px;
        background: rgba(233,69,96,0.1);
        border: 1px solid #e94560;
        border-radius: 6px;
        color: #e94560;
        font-size: 14px;
        text-align: left;
    }

    .example-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        justify-content: center;
        margin-top: 24px;
    }

    .example-chip {
        padding: 6px 14px;
        background: #1a1a2e;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 20px;
        color: #8892a4;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .example-chip:hover {
        border-color: #e94560;
        color: #e94560;
    }
</style>

<div class="search-page">
    <div class="search-logo">🎮</div>
    <h1 class="search-title">Player Search</h1>
    <p class="search-subtitle">Search any EUW player by Riot ID to see their recent matches and stats</p>

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="search-box">
            <input type="text"
                   name="riotId"
                   class="search-input"
                   placeholder="Faker#EUW"
                   autocomplete="off"
                   autofocus />
            <button type="submit" class="search-btn">Search →</button>
        </div>
        <p class="search-hint">Format: GameName#TAG &nbsp;·&nbsp; EUW only</p>

        @if (!ViewData.ModelState.IsValid)
        {
            foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div class="search-error">⚠️ @error.ErrorMessage</div>
            }
        }
    </form>

    <script>
        document.querySelector('.search-input').addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                this.closest('form').submit();
            }
        });
    </script>

    <div class="example-chips">
        <span class="example-chip" onclick="document.querySelector('.search-input').value='Faker#EUW1'">Faker#EUW1</span>
        <span class="example-chip" onclick="document.querySelector('.search-input').value='Caps#EUW'">Caps#EUW</span>
        <span class="example-chip" onclick="document.querySelector('.search-input').value='Rekkles#EUW'">Rekkles#EUW</span>
    </div>
</div>