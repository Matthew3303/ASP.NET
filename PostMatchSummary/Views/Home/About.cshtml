@{
    ViewData["Title"] = "About";
}

<style>
    :root {
        --bg-primary: #0f0f1a;
        --bg-surface: #1a1a2e;
        --bg-elevated: #16213e;
        --accent-red: #e94560;
        --accent-blue: #0f3460;
        --accent-purple: #533483;
        --accent-gold: #ffd700;
        --text-primary: #e0e0e0;
        --text-muted: #8892a4;
        --win: #00b894;
        --loss: #e94560;
    }

    .breadcrumb-nav {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 32px;
        font-size: 14px;
    }

    .breadcrumb-nav a {
        color: var(--accent-red);
        text-decoration: none;
        transition: color 0.2s;
    }

    .breadcrumb-nav a:hover {
        color: var(--text-primary);
    }

    .breadcrumb-nav .sep {
        color: var(--text-muted);
    }

    .breadcrumb-nav .current {
        color: var(--text-primary);
        font-weight: 500;
    }

    .about-container {
        max-width: 1000px;
    }

    .hero-section {
        background: linear-gradient(135deg, rgba(233, 69, 96, 0.1) 0%, rgba(15, 52, 96, 0.1) 100%);
        border: 1px solid rgba(233, 69, 96, 0.2);
        border-radius: 8px;
        padding: 48px;
        margin-bottom: 40px;
        text-align: center;
    }

    .hero-title {
        color: var(--accent-red);
        font-size: 42px;
        font-weight: 700;
        margin: 0 0 12px 0;
    }

    .hero-subtitle {
        color: var(--text-muted);
        font-size: 18px;
        margin: 0;
        line-height: 1.5;
    }

    .card {
        background: var(--bg-surface);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 8px;
        padding: 40px;
        box-shadow: 0 2px 12px rgba(0, 0, 0, 0.4);
        margin-bottom: 32px;
        transition: box-shadow 0.3s;
    }

    .card:hover {
        box-shadow: 0 4px 24px rgba(233, 69, 96, 0.15);
    }

    .card-header {
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 2px solid rgba(233, 69, 96, 0.2);
    }

    .card-title {
        color: var(--text-primary);
        font-size: 28px;
        font-weight: 700;
        margin: 0 0 8px 0;
    }

    .card-subtitle {
        color: var(--text-muted);
        font-size: 15px;
        margin: 0;
    }

    .section {
        margin-bottom: 40px;
    }

    .section:last-child {
        margin-bottom: 0;
    }

    .section-title {
        color: var(--accent-red);
        font-size: 20px;
        font-weight: 600;
        margin-bottom: 24px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .section-content {
        color: var(--text-primary);
        line-height: 1.7;
        font-size: 15px;
    }

    .section-content p {
        margin-bottom: 16px;
    }

    .section-content ul {
        margin: 16px 0;
        padding-left: 24px;
        list-style-position: outside;
    }

    .section-content li {
        margin-bottom: 12px;
        color: var(--text-primary);
    }

    .tech-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-top: 24px;
    }

    .tech-card {
        background: rgba(233, 69, 96, 0.08);
        border: 1px solid rgba(233, 69, 96, 0.25);
        border-radius: 6px;
        padding: 24px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .tech-card:hover {
        background: rgba(233, 69, 96, 0.15);
        border-color: rgba(233, 69, 96, 0.4);
        transform: translateY(-4px);
        box-shadow: 0 4px 16px rgba(233, 69, 96, 0.2);
    }

    .tech-icon {
        font-size: 40px;
        margin-bottom: 12px;
        display: inline-block;
    }

    .tech-name {
        color: var(--accent-red);
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 8px;
    }

    .tech-desc {
        color: var(--text-muted);
        font-size: 13px;
        line-height: 1.5;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 32px;
        color: var(--accent-red);
        text-decoration: none;
        font-size: 14px;
        transition: color 0.2s;
    }

    .back-link:hover {
        color: var(--text-primary);
    }

    .button-group {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        margin-top: 32px;
        justify-content: flex-start;
    }

    .btn {
        display: inline-block;
        padding: 12px 28px;
        border: 2px solid var(--accent-red);
        border-radius: 4px;
        background: transparent;
        color: var(--accent-red);
        text-decoration: none;
        font-weight: 600;
        font-size: 14px;
        transition: all 0.2s;
        cursor: pointer;
    }

    .btn:hover {
        background: var(--accent-red);
        color: var(--bg-primary);
        transform: translateY(-2px);
    }

    @@media (max-width: 768px) {
        .hero-section {
            padding: 32px;
        }

        .hero-title {
            font-size: 32px;
        }

        .hero-subtitle {
            font-size: 16px;
        }

        .card {
            padding: 24px;
        }

        .tech-grid {
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
        }

        .button-group {
            flex-direction: column;
        }

        .btn {
            width: 100%;
            text-align: center;
        }
    }
</style>

<a asp-controller="Home" asp-action="Index" class="back-link">← Back to Home</a>

<nav class="breadcrumb-nav">
    <a asp-controller="Home" asp-action="Index">🏠 Home</a>
    <span class="sep">›</span>
    <span class="current">About</span>
</nav>

<div class="about-container">
    <!-- Hero Section -->
    <div class="hero-section">
        <h1 class="hero-title">PostMatchSummary</h1>
        <p class="hero-subtitle">Deep dive into League of Legends match analytics and player statistics</p>
    </div>

    <!-- Main About Section -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">📋 About The Application</h2>
            <p class="card-subtitle">Comprehensive match analysis and performance tracking</p>
        </div>

        <div class="section">
            <div class="section-content">
                <p>
                    <strong>PostMatchSummary</strong> is a web application designed for analyzing and viewing detailed data 
                    from League of Legends matches. The application empowers users to:
                </p>
                <ul>
                    <li>View all available matches in the database with complete details</li>
                    <li>Analyze detailed statistics for each player across all matches</li>
                    <li>Track performance metrics by role and champion selection</li>
                    <li>Compare match results and player performance trends</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Technologies Section -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">🛠️ Technologies Used</h2>
            <p class="card-subtitle">Modern tech stack for robust performance</p>
        </div>

        <div class="tech-grid">
            <div class="tech-card">
                <div class="tech-icon">⚙️</div>
                <div class="tech-name">ASP.NET Core</div>
                <div class="tech-desc">Modern web framework for building server-side applications</div>
            </div>
            <div class="tech-card">
                <div class="tech-icon">🗄️</div>
                <div class="tech-name">Entity Framework</div>
                <div class="tech-desc">Object-relational mapping for seamless database operations</div>
            </div>
            <div class="tech-card">
                <div class="tech-icon">💾</div>
                <div class="tech-name">SQL Server</div>
                <div class="tech-desc">Enterprise-grade relational database management</div>
            </div>
            <div class="tech-card">
                <div class="tech-icon">🎨</div>
                <div class="tech-name">HTML/CSS</div>
                <div class="tech-desc">Frontend technologies for responsive user interface</div>
            </div>
            <div class="tech-card">
                <div class="tech-icon">✨</div>
                <div class="tech-name">Razor Views</div>
                <div class="tech-desc">Template engine for dynamic server-side rendering</div>
            </div>
            <div class="tech-card">
                <div class="tech-icon">🔗</div>
                <div class="tech-name">REST API</div>
                <div class="tech-desc">Data exchange protocol between application components</div>
            </div>
        </div>
    </div>

    <!-- Features Section -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">✨ Key Features</h2>
            <p class="card-subtitle">Core capabilities of the platform</p>
        </div>

        <div class="section-content">
            <ul>
                <li><strong>Dashboard:</strong> Quick overview of all matches and players with key statistics at a glance</li>
                <li><strong>Match List:</strong> Comprehensive view of all available matches with filterable details</li>
                <li><strong>Player Profiles:</strong> Detailed information about each player and their performance metrics</li>
                <li><strong>Custom Routing:</strong> Optimized URL patterns for enhanced user experience and SEO</li>
                <li><strong>Responsive Design:</strong> Application is fully optimized for all screen sizes and devices</li>
            </ul>
        </div>
    </div>

    <!-- Usage Section -->
    <div class="card">
        <div class="card-header">
            <h2 class="card-title">🚀 How to Use</h2>
            <p class="card-subtitle">Navigate through the application</p>
        </div>

        <div class="section-content">
            <p>
                Start with the <strong>Home</strong> page to get an overview of all available data. 
                Use the navigation sidebar on the left to access different sections of the application:
            </p>
            <ul>
                <li><strong>Home (🏠):</strong> Dashboard displaying key statistics and recent activity</li>
                <li><strong>Matches (⚔️):</strong> Complete list of all available matches with search capabilities</li>
                <li><strong>Players (👥):</strong> Directory of all players with their detailed performance history</li>
            </ul>
        </div>
    </div>

    <!-- Footer with Navigation -->
    <div class="button-group">
        <a asp-controller="Home" asp-action="Index" class="btn">🏠 Back to Home</a>
        <a asp-controller="PostMatch" asp-action="Index" class="btn">⚔️ View Matches</a>
        <a asp-controller="Player" asp-action="Index" class="btn">👥 View Players</a>
    </div>
</div>
