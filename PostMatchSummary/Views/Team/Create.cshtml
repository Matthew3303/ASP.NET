@model PostMatchSummary.Models.Team

@{
    ViewData["Title"] = "Add New Team";
}

<style>
    .form-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 24px;
        background: var(--bg-surface);
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    .form-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 24px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 6px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control, select {
        width: 100%;
        padding: 10px 12px;
        background: var(--bg-elevated);
        border: 2px solid var(--bg-surface);
        color: var(--text-primary);
        border-radius: 4px;
        font-size: 14px;
        transition: all 0.2s ease;
        box-sizing: border-box;
    }

    select {
        cursor: pointer;
    }

    .form-control:focus, select:focus {
        outline: none;
        border-color: var(--accent-red);
        box-shadow: 0 0 0 3px rgba(233, 69, 96, 0.1);
    }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .checkbox-group input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .form-buttons {
        display: flex;
        gap: 12px;
        margin-top: 32px;
    }

    .btn-submit, .btn-cancel {
        flex: 1;
        padding: 12px 16px;
        border: none;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-submit {
        background: var(--accent-red);
        color: var(--text-primary);
    }

    .btn-submit:hover {
        background: #d43050;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(233, 69, 96, 0.3);
    }

    .btn-cancel {
        background: var(--bg-elevated);
        color: var(--text-primary);
        border: 1px solid var(--accent-red);
        text-decoration: none;
        text-align: center;
    }

    .btn-cancel:hover {
        background: var(--accent-red);
    }

    .validation-errors {
        background: rgba(233, 69, 96, 0.1);
        border: 1px solid var(--loss);
        border-radius: 4px;
        padding: 12px;
        margin-bottom: 20px;
        color: var(--loss);
    }

    .validation-errors ul {
        margin: 0;
        padding-left: 20px;
    }

    .validation-errors li {
        margin: 4px 0;
    }
</style>

<div class="form-container">
    <h1 class="form-title">Add New Team</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="validation-errors">
            <strong>Validation errors:</strong>
            <ul>
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                    @foreach (var error in modelState.Errors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                }
            </ul>
        </div>
    }

    <form method="post" action="/api/teams/create">
        <div class="form-group">
            <label for="TeamId" class="form-label">Team *</label>
            <select id="TeamId" name="TeamId" required>
                <option value="">- Select -</option>
                <option value="100" asp-selected="Model?.TeamId == 100">Blue Team</option>
                <option value="200" asp-selected="Model?.TeamId == 200">Red Team</option>
            </select>
        </div>

        <div class="form-group">
            <label class="form-label">Victory Status *</label>
            <div class="checkbox-group">
                <input type="checkbox" id="Win" name="Win" value="true" @(Model?.Win == true ? "checked" : "") />
                <label for="Win">Team has won</label>
            </div>
        </div>

        <div class="form-buttons">
            <button type="submit" class="btn-submit">✅ Save</button>
            <a href="/api/teams/" class="btn-cancel">❌ Cancel</a>
        </div>
    </form>
</div>
