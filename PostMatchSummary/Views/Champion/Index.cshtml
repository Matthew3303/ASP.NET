@model List<PostMatchSummary.Models.Champion>

@{
    ViewData["Title"] = "All Champions";
}

<style>
    .breadcrumb-nav {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 24px;
        font-size: 14px;
    }

    .breadcrumb {
        margin-bottom: 32px;
        font-size: 14px;
    }

    .breadcrumb-item.active {
        color: var(--text-primary);
    }

    .breadcrumb-item a {
        color: var(--accent-red);
        text-decoration: none;
    }

    .breadcrumb-item a:hover {
        text-decoration: underline;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
        flex-wrap: wrap;
        gap: 16px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        color: var(--text-primary);
        margin: 0;
    }

    .search-container {
        display: flex;
        gap: 8px;
        flex: 1;
        min-width: 250px;
    }

    .search-container input {
        flex: 1;
        padding: 10px 12px;
        background: var(--bg-elevated);
        border: 2px solid var(--bg-surface);
        color: var(--text-primary);
        border-radius: 4px;
        font-size: 14px;
        transition: all 0.2s ease;
    }

    .search-container input:focus {
        outline: none;
        border-color: var(--accent-red);
        box-shadow: 0 0 0 3px rgba(233, 69, 96, 0.1);
    }

    .btn-primary {
        padding: 10px 16px;
        background: var(--accent-red);
        color: var(--text-primary);
        border: none;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-primary:hover {
        background: #d43050;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(233, 69, 96, 0.3);
    }

    .btn-secondary {
        padding: 6px 12px;
        background: var(--bg-surface);
        color: var(--text-primary);
        border: 1px solid var(--accent-red);
        border-radius: 4px;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .btn-secondary:hover {
        background: var(--accent-red);
        color: var(--text-primary);
    }

    .btn-danger {
        background: var(--loss);
    }

    .btn-danger:hover {
        background: #d63650;
    }

    .champions-table {
        width: 100%;
        border-collapse: collapse;
        background: var(--bg-surface);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    .champions-table thead {
        background: var(--bg-elevated);
        border-bottom: 2px solid var(--accent-red);
    }

    .champions-table th {
        padding: 16px 12px;
        text-align: left;
        color: var(--text-primary);
        font-weight: 600;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .champions-table td {
        padding: 14px 12px;
        border-bottom: 1px solid var(--bg-elevated);
        color: var(--text-primary);
    }

    .champions-table tbody tr {
        transition: all 0.2s ease;
    }

    .champions-table tbody tr:hover {
        background: var(--bg-elevated);
        transform: scale(1.01);
    }

    .champions-table tbody tr:last-child td {
        border-bottom: none;
    }

    .actions {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }

    .empty-state {
        text-align: center;
        padding: 40px 20px;
        color: var(--text-muted);
    }

    .empty-state-icon {
        font-size: 48px;
        margin-bottom: 16px;
        opacity: 0.5;
    }

    .spinner {
        display: none;
        width: 16px;
        height: 16px;
        border: 2px solid var(--text-muted);
        border-top-color: var(--accent-red);
        border-radius: 50%;
        animation: spin 0.6s linear infinite;
        margin-right: 8px;
    }

    .spinner.show {
        display: inline-block;
    }

    .champions-table .champion-badge-icon {
        width: 42px;
        height: 42px;
        border-radius: 8px;
    }

    .champions-table .champion-badge-with-icon {
        gap: 12px;
    }

    .champions-table .champion-badge-name {
        font-size: 16px;
        font-weight: 600;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>

<nav class="breadcrumb-nav">
    <a href="/" style="color: var(--accent-red); text-decoration: none;">🏠 Home</a>
    <span style="color: var(--text-muted);">›</span>
    <span style="color: var(--text-primary);">⚔️ Champions</span>
</nav>

<div class="page-header">
    <h1 class="page-title">All Champions</h1>
    <a href="/api/champions/create" class="btn-primary">+ Add Champion</a>
</div>

<div class="search-container" style="margin-bottom: 24px;">
    <input type="text" id="searchBox" placeholder="Search champions..." autocomplete="off" />
    <button type="button" id="searchBtn" class="btn-secondary">🔍 Search</button>
    <button type="button" id="clearBtn" class="btn-secondary">✕ Clear</button>
    <div class="spinner" id="searchSpinner"></div>
</div>

@if (Model.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">📋</div>
        <p>No champions registered</p>
    </div>
}
else
{
    <table class="champions-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="championsTableBody">
            @foreach (var champion in Model.OrderBy(c => c.Name))
            {
                <tr>
                    <td>@champion.Id</td>
                    <td>@await Html.PartialAsync("_ChampionBadge", champion)</td>
                    <td class="actions">
                        <a href="/api/champions/@champion.Id/edit" class="btn-secondary">✏️ Edit</a>
                        <a href="/api/champions/@champion.Id/delete" class="btn-secondary btn-danger">🗑️ Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@section Scripts {
    <script>
        document.getElementById('searchBox').addEventListener('keyup', function(e) {
            const filterValue = e.target.value.toLowerCase();
            document.querySelectorAll('#championsTableBody tr').forEach(row => {
                const nameCell = row.querySelector('td:nth-child(2)');
                const nameText = nameCell ? nameCell.textContent.toLowerCase() : '';
                row.style.display = nameText.includes(filterValue) ? '' : 'none';
            });
        });

        document.getElementById('clearBtn').addEventListener('click', function() {
            document.getElementById('searchBox').value = '';
            document.querySelectorAll('#championsTableBody tr').forEach(row => {
                row.style.display = '';
            });
        });

        document.getElementById('searchBtn').addEventListener('click', function() {
            document.getElementById('searchBox').dispatchEvent(new Event('keyup'));
        });
    </script>
}