@model PostMatchSummary.Models.Champion

@{
    ViewData["Title"] = "Delete Champion";
}

<style>
    .delete-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 24px;
        background: rgba(233, 69, 96, 0.1);
        border: 2px solid var(--loss);
        border-radius: 8px;
    }

    .delete-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--loss);
        margin-bottom: 16px;
    }

    .delete-content {
        color: var(--text-primary);
        margin-bottom: 24px;
    }

    .delete-info {
        background: var(--bg-surface);
        padding: 16px;
        border-radius: 4px;
        margin: 16px 0;
    }

    .delete-info-label {
        font-size: 12px;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .delete-info-value {
        font-size: 16px;
        color: var(--text-primary);
        margin-top: 4px;
    }

    .warning-box {
        background: rgba(233, 69, 96, 0.1);
        border-left: 4px solid var(--loss);
        padding: 12px;
        margin: 16px 0;
        color: var(--loss);
        font-size: 14px;
    }

    .form-buttons {
        display: flex;
        gap: 12px;
        margin-top: 24px;
    }

    .btn-danger {
        flex: 1;
        padding: 12px 16px;
        background: var(--loss);
        color: var(--text-primary);
        border: none;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-danger:hover {
        background: #d63650;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(233, 69, 96, 0.3);
    }

    .btn-cancel {
        flex: 1;
        padding: 12px 16px;
        background: var(--bg-elevated);
        color: var(--text-primary);
        border: 1px solid var(--text-muted);
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
    }

    .btn-cancel:hover {
        background: var(--bg-surface);
        border-color: var(--accent-red);
    }
</style>

<div class="delete-container">
    <h1 class="delete-title">⚠️ Delete Champion</h1>

    <div class="delete-content">
        <p>Are you sure you want to delete this champion?</p>
        
        <div class="delete-info">
            <div class="delete-info-label">Champion Name</div>
            <div class="delete-info-value">@Model.Name</div>
        </div>

        @if (Model.Players.Count > 0)
        {
            <div class="warning-box">
                <strong>⚠️ Warning:</strong> This champion has @Model.Players.Count player(s) associated with it. It cannot be deleted to prevent referential integrity issues.
            </div>
        }
        else
        {
            <div class="warning-box">
                Deletion is permanent and cannot be undone. All associated data will be deleted.
            </div>
        }
    </div>

    @if (Model.Players.Count > 0)
    {
        <div class="form-buttons">
            <a href="/api/champions/" class="btn-cancel">← Back</a>
        </div>
    }
    else
    {
        <form method="post" action="/api/champions/@Model.Id/delete" style="display: flex; gap: 12px;">
            <button type="submit" class="btn-danger" style="flex: 1;">🗑️ Confirm Delete</button>
            <a href="/api/champions/" class="btn-cancel" style="flex: 1;">❌ Cancel</a>
        </form>
    }
</div>
