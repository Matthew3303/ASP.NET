@model PostMatchSummary.Models.Champion

@{
    ViewData["Title"] = "Edit Champion";
}

<style>
    .form-container {
        max-width: 600px;
        margin: 0 auto;
        padding: 24px;
        background: var(--bg-surface);
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    .form-title {
        font-size: 24px;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 24px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        display: block;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 6px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control {
        width: 100%;
        padding: 10px 12px;
        background: var(--bg-elevated);
        border: 2px solid var(--bg-surface);
        color: var(--text-primary);
        border-radius: 4px;
        font-size: 14px;
        transition: all 0.2s ease;
        box-sizing: border-box;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--accent-red);
        box-shadow: 0 0 0 3px rgba(233, 69, 96, 0.1);
    }

    .form-error {
        color: var(--loss);
        font-size: 12px;
        margin-top: 4px;
        display: none;
    }

    .form-error.show {
        display: block;
    }

    .validation-errors {
        background: rgba(233, 69, 96, 0.1);
        border: 1px solid var(--loss);
        border-radius: 4px;
        padding: 12px;
        margin-bottom: 20px;
        color: var(--loss);
    }

    .validation-errors ul {
        margin: 0;
        padding-left: 20px;
    }

    .validation-errors li {
        margin: 4px 0;
    }

    .form-buttons {
        display: flex;
        gap: 12px;
        margin-top: 32px;
    }

    .btn-submit {
        flex: 1;
        padding: 12px 16px;
        background: var(--accent-red);
        color: var(--text-primary);
        border: none;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .btn-submit:hover {
        background: #d43050;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(233, 69, 96, 0.3);
    }

    .btn-cancel {
        flex: 1;
        padding: 12px 16px;
        background: var(--bg-elevated);
        color: var(--text-primary);
        border: 1px solid var(--accent-red);
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
    }

    .btn-cancel:hover {
        background: var(--accent-red);
        color: var(--text-primary);
    }

    .btn-danger {
        flex: 1;
        padding: 12px 16px;
        background: var(--loss);
        color: var(--text-primary);
        border: none;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
    }

    .btn-danger:hover {
        background: #d63650;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(233, 69, 96, 0.3);
    }
</style>

<div class="form-container">
    <h1 class="form-title">Edit Champion</h1>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="validation-errors">
            <strong>Errors during validation:</strong>
            <ul>
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                    @foreach (var error in modelState.Errors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                }
            </ul>
        </div>
    }

    <form method="post" action="/api/champions/@Model.Id/edit">
        <div class="form-group">
            <label for="Name" class="form-label">Champion Name *</label>
            <input type="text" id="Name" name="Name" class="form-control" value="@Model.Name" required />
            @if (ViewData.ModelState.ContainsKey("Name") && ViewData.ModelState["Name"]?.Errors.Count > 0)
            {
                <div class="form-error show">
                    @ViewData.ModelState["Name"]?.Errors[0].ErrorMessage
                </div>
            }
        </div>

        <div class="form-buttons">
            <button type="submit" class="btn-submit">✅ Save</button>
            <a href="/api/champions/" class="btn-cancel">❌ Cancel</a>
            <a href="/api/champions/@Model.Id/delete" class="btn-danger">🗑️ Delete</a>
        </div>
    </form>
</div>
